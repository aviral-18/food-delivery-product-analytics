# ============================================================
#  Eternal Product Analytics — Backend environment
#  Copy to `.env` and adjust for your machine.
# ============================================================

# --- Application ---
APP_NAME="Eternal Product Analytics"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- PostgreSQL ---
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
# NOTE: never commit your real .env — only this template belongs in git.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/food_delivery_analytics
SQL_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Security / JWT ---
# Generate a strong key with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_super_secret_dev_key_please_rotate_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (frontend origins) ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Synthetic data generation ---
SEED=42
GEN_CUSTOMERS=30000
GEN_RESTAURANTS=2000
GEN_PARTNERS=100
GEN_ORDERS=120000
GEN_MONTHS=24
